
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GroqAI — Plataforma</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #080c14;
  --sidebar: #0b1120;
  --surface: #0f1623;
  --surface2: #141d2e;
  --border: rgba(99,179,237,0.12);
  --border2: rgba(255,255,255,0.06);
  --accent: #63b3ed;
  --accent2: #f6ad55;
  --accent3: #68d391;
  --text: #e2e8f0;
  --muted: #4a5568;
  --muted2: #718096;
  --danger: #fc8181;
  --sidebar-w: 260px;
  --header-h: 60px;
}
html, body { height: 100%; overflow: hidden; }
body { background: var(--bg); font-family: 'DM Sans', sans-serif; color: var(--text); display: flex; flex-direction: column; }

/* ── HEADER ── */
.header {
  height: var(--header-h); min-height: var(--header-h);
  background: var(--sidebar);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 0 20px; gap: 16px; z-index: 100;
}
.header-logo {
  display: flex; align-items: center; gap: 10px;
  font-family: 'Syne', sans-serif; font-size: 1.2rem; font-weight: 800;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.header-logo-icon {
  width: 32px; height: 32px; border-radius: 8px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
}
.header-logo-icon svg { width: 16px; height: 16px; fill: #080c14; }
.header-spacer { flex: 1; }
.header-user {
  display: flex; align-items: center; gap: 10px;
  font-size: 0.875rem; color: var(--muted2);
}
.avatar {
  width: 32px; height: 32px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  font-family: 'Syne', sans-serif; font-size: 0.75rem; font-weight: 700;
  color: #080c14;
}
.btn-icon {
  width: 34px; height: 34px; border-radius: 8px;
  background: transparent; border: 1px solid var(--border2);
  color: var(--muted2); cursor: pointer; display: flex;
  align-items: center; justify-content: center;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
}
.btn-icon:hover { background: var(--surface2); color: var(--text); border-color: var(--border); }
.btn-icon svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

/* ── LAYOUT ── */
.app-body { flex: 1; display: flex; overflow: hidden; }

/* ── SIDEBAR ── */
.sidebar {
  width: var(--sidebar-w); min-width: var(--sidebar-w);
  background: var(--sidebar);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  overflow: hidden;
  transition: transform 0.3s ease;
}
.sidebar-section { padding: 14px 12px 8px; }
.sidebar-label {
  font-size: 0.68rem; font-weight: 500; text-transform: uppercase;
  letter-spacing: 0.12em; color: var(--muted); padding: 0 4px; margin-bottom: 8px;
}
.mode-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.mode-btn {
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  padding: 10px 6px; border-radius: 10px;
  background: var(--surface2); border: 1px solid var(--border2);
  cursor: pointer; transition: all 0.2s; text-align: center;
  color: var(--muted2); font-size: 0.72rem; font-family: 'DM Sans', sans-serif;
}
.mode-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; margin-bottom: 2px; }
.mode-btn:hover, .mode-btn.active {
  background: rgba(99,179,237,0.1); border-color: var(--accent);
  color: var(--accent);
}
.mode-btn.active { box-shadow: 0 0 10px rgba(99,179,237,0.2); }

/* Mode colors */
.mode-btn[data-mode="vision"]:hover, .mode-btn[data-mode="vision"].active { background: rgba(246,173,85,0.1); border-color: var(--accent2); color: var(--accent2); box-shadow: 0 0 10px rgba(246,173,85,0.2); }
.mode-btn[data-mode="transcription"]:hover, .mode-btn[data-mode="transcription"].active { background: rgba(104,211,145,0.1); border-color: var(--accent3); color: var(--accent3); box-shadow: 0 0 10px rgba(104,211,145,0.2); }
.mode-btn[data-mode="translation"]:hover, .mode-btn[data-mode="translation"].active { background: rgba(183,148,246,0.1); border-color: #b794f4; color: #b794f4; box-shadow: 0 0 10px rgba(183,148,246,0.2); }

.sidebar-divider { height: 1px; background: var(--border); margin: 4px 12px; }

.conversations-list { flex: 1; overflow-y: auto; padding: 0 8px 12px; }
.conversations-list::-webkit-scrollbar { width: 3px; }
.conversations-list::-webkit-scrollbar-track { background: transparent; }
.conversations-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

.conv-item {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 10px; border-radius: 8px; margin-bottom: 2px;
  cursor: pointer; transition: background 0.15s;
  border: 1px solid transparent;
}
.conv-item:hover { background: var(--surface2); }
.conv-item.active { background: rgba(99,179,237,0.08); border-color: var(--border); }
.conv-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--muted); flex-shrink: 0; }
.conv-item.active .conv-dot { background: var(--accent); }
.conv-title { flex: 1; font-size: 0.8rem; color: var(--muted2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.conv-item.active .conv-title { color: var(--text); }
.conv-del {
  opacity: 0; width: 20px; height: 20px; border-radius: 4px;
  background: transparent; border: none; cursor: pointer;
  color: var(--muted); display: flex; align-items: center; justify-content: center;
  transition: opacity 0.2s, background 0.2s, color 0.2s; flex-shrink: 0;
}
.conv-item:hover .conv-del { opacity: 1; }
.conv-del:hover { background: rgba(252,129,129,0.15); color: var(--danger); }
.conv-del svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; }

/* ── MAIN CHAT ── */
.chat-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative; }

.chat-header {
  padding: 14px 24px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 12px; flex-shrink: 0;
  background: rgba(8,12,20,0.8); backdrop-filter: blur(10px);
}
.chat-header-title { font-family: 'Syne', sans-serif; font-size: 0.95rem; font-weight: 700; flex: 1; }
.mode-badge {
  font-size: 0.72rem; padding: 3px 10px; border-radius: 100px;
  background: rgba(99,179,237,0.1); border: 1px solid rgba(99,179,237,0.3); color: var(--accent);
}
.mode-badge.vision { background: rgba(246,173,85,0.1); border-color: rgba(246,173,85,0.3); color: var(--accent2); }
.mode-badge.transcription { background: rgba(104,211,145,0.1); border-color: rgba(104,211,145,0.3); color: var(--accent3); }
.mode-badge.translation { background: rgba(183,148,246,0.1); border-color: rgba(183,148,246,0.3); color: #b794f4; }

/* Empty state */
.empty-state {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 40px; text-align: center;
}
.empty-icon {
  width: 72px; height: 72px; border-radius: 20px; margin-bottom: 20px;
  background: linear-gradient(135deg, rgba(99,179,237,0.15), rgba(246,173,85,0.15));
  border: 1px solid var(--border); display: flex; align-items: center; justify-content: center;
}
.empty-icon svg { width: 32px; height: 32px; stroke: var(--accent); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
.empty-state h3 { font-family: 'Syne', sans-serif; font-size: 1.3rem; font-weight: 700; margin-bottom: 8px; }
.empty-state p { color: var(--muted2); font-size: 0.875rem; max-width: 360px; line-height: 1.6; }
.suggestions { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 24px; }
.suggestion-chip {
  padding: 8px 16px; border-radius: 100px;
  background: var(--surface2); border: 1px solid var(--border2);
  font-size: 0.8rem; color: var(--muted2); cursor: pointer;
  transition: all 0.2s;
}
.suggestion-chip:hover { background: rgba(99,179,237,0.1); border-color: var(--border); color: var(--accent); }

/* Messages */
.messages-container {
  flex: 1; overflow-y: auto; padding: 24px;
  display: flex; flex-direction: column; gap: 20px;
}
.messages-container::-webkit-scrollbar { width: 4px; }
.messages-container::-webkit-scrollbar-track { background: transparent; }
.messages-container::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

.message { display: flex; gap: 12px; animation: msgIn 0.3s ease; }
@keyframes msgIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

.message.user { flex-direction: row-reverse; }

.msg-avatar {
  width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem; font-weight: 700; font-family: 'Syne', sans-serif;
}
.message.user .msg-avatar { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #080c14; }
.message.assistant .msg-avatar { background: var(--surface2); border: 1px solid var(--border); color: var(--muted2); }

.msg-content { max-width: 70%; }
.message.user .msg-content { align-items: flex-end; }

.msg-bubble {
  padding: 12px 16px; border-radius: 16px;
  font-size: 0.9rem; line-height: 1.65;
}
.message.user .msg-bubble {
  background: linear-gradient(135deg, rgba(99,179,237,0.2), rgba(99,179,237,0.12));
  border: 1px solid rgba(99,179,237,0.25);
  border-radius: 16px 4px 16px 16px;
}
.message.assistant .msg-bubble {
  background: var(--surface2); border: 1px solid var(--border2);
  border-radius: 4px 16px 16px 16px;
}

.msg-bubble p { margin-bottom: 8px; }
.msg-bubble p:last-child { margin-bottom: 0; }
.msg-bubble strong { color: var(--accent); font-weight: 600; }
.msg-bubble code {
  font-family: 'JetBrains Mono', monospace; font-size: 0.82em;
  background: rgba(0,0,0,0.3); padding: 2px 6px; border-radius: 4px;
  border: 1px solid var(--border);
}
.msg-bubble pre {
  background: rgba(0,0,0,0.4); border: 1px solid var(--border);
  border-radius: 8px; padding: 12px; margin: 8px 0; overflow-x: auto;
  font-family: 'JetBrains Mono', monospace; font-size: 0.8em; line-height: 1.5;
}
.msg-bubble ul, .msg-bubble ol { padding-left: 18px; margin: 6px 0; }
.msg-bubble li { margin: 3px 0; }

.msg-image { max-width: 280px; border-radius: 10px; margin-bottom: 8px; border: 1px solid var(--border); }

.msg-time { font-size: 0.7rem; color: var(--muted); margin-top: 4px; padding: 0 4px; }
.message.user .msg-time { text-align: right; }

/* Typing indicator */
.typing-indicator { display: flex; gap: 4px; align-items: center; padding: 14px 16px; }
.typing-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); animation: typingBounce 1s ease infinite; }
.typing-dot:nth-child(2) { animation-delay: 0.15s; }
.typing-dot:nth-child(3) { animation-delay: 0.3s; }
@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-6px); opacity: 1; }
}

/* ── INPUT AREA ── */
.input-area {
  padding: 16px 24px; border-top: 1px solid var(--border);
  background: rgba(8,12,20,0.9); backdrop-filter: blur(10px); flex-shrink: 0;
}

/* Mode tabs */
.mode-tabs { display: flex; gap: 6px; margin-bottom: 12px; }
.mode-tab {
  display: flex; align-items: center; gap: 6px;
  padding: 5px 12px; border-radius: 100px; font-size: 0.78rem;
  background: var(--surface2); border: 1px solid var(--border2);
  cursor: pointer; transition: all 0.2s; color: var(--muted2);
  font-family: 'DM Sans', sans-serif;
}
.mode-tab svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
.mode-tab.active { background: rgba(99,179,237,0.12); border-color: var(--accent); color: var(--accent); }

/* Chat input panel */
.input-panel { position: relative; }
.chat-input-wrap {
  display: flex; gap: 10px; align-items: flex-end;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 14px; padding: 10px 12px;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.chat-input-wrap:focus-within {
  border-color: rgba(99,179,237,0.4);
  box-shadow: 0 0 0 3px rgba(99,179,237,0.08);
}
.chat-textarea {
  flex: 1; background: transparent; border: none; outline: none; resize: none;
  color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 0.9rem; line-height: 1.5;
  min-height: 24px; max-height: 150px; overflow-y: auto;
}
.chat-textarea::placeholder { color: var(--muted); }
.chat-textarea::-webkit-scrollbar { width: 3px; }

.btn-send {
  width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
  background: linear-gradient(135deg, var(--accent), #4299e1);
  border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: transform 0.15s, box-shadow 0.15s, opacity 0.2s;
}
.btn-send:hover { transform: scale(1.05); box-shadow: 0 4px 12px rgba(99,179,237,0.4); }
.btn-send:disabled { opacity: 0.4; cursor: default; transform: none; box-shadow: none; }
.btn-send svg { width: 16px; height: 16px; stroke: #080c14; fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }

/* Image upload panel */
.vision-panel { display: none; }
.vision-panel.active { display: block; }
.drop-zone {
  border: 2px dashed rgba(246,173,85,0.3); border-radius: 12px;
  padding: 20px; text-align: center; cursor: pointer;
  transition: all 0.2s; background: rgba(246,173,85,0.03);
  margin-bottom: 10px;
}
.drop-zone:hover, .drop-zone.dragover {
  border-color: var(--accent2); background: rgba(246,173,85,0.06);
}
.drop-zone input[type="file"] { display: none; }
.drop-zone-icon { font-size: 2rem; margin-bottom: 8px; }
.drop-zone p { font-size: 0.82rem; color: var(--muted2); }
.drop-zone strong { color: var(--accent2); }
.image-preview { position: relative; display: inline-block; margin-bottom: 10px; }
.image-preview img { max-height: 120px; border-radius: 8px; border: 1px solid var(--border); }
.image-preview-del {
  position: absolute; top: -6px; right: -6px;
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--danger); border: 2px solid var(--bg);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  color: white; font-size: 0.7rem; font-weight: 700; line-height: 1;
}

/* Audio panel */
.audio-panel { display: none; }
.audio-panel.active { display: block; }
.audio-controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.btn-record {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 18px; border-radius: 10px;
  background: rgba(104,211,145,0.1); border: 1px solid rgba(104,211,145,0.3);
  color: var(--accent3); cursor: pointer; font-size: 0.85rem;
  font-family: 'DM Sans', sans-serif; transition: all 0.2s;
}
.btn-record:hover { background: rgba(104,211,145,0.15); }
.btn-record.recording { background: rgba(252,129,129,0.1); border-color: rgba(252,129,129,0.3); color: var(--danger); animation: recordPulse 1.5s ease infinite; }
@keyframes recordPulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(252,129,129,0.3); } 50% { box-shadow: 0 0 0 6px rgba(252,129,129,0); } }
.record-dot { width: 10px; height: 10px; border-radius: 50%; background: currentColor; }
.btn-record.recording .record-dot { animation: blink 1s ease infinite; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
.audio-file-label {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 14px; border-radius: 8px;
  background: var(--surface2); border: 1px solid var(--border2);
  cursor: pointer; font-size: 0.82rem; color: var(--muted2); transition: all 0.2s;
}
.audio-file-label:hover { border-color: var(--accent3); color: var(--accent3); }
.audio-file-label svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; }
.audio-file-input { display: none; }
.audio-name { font-size: 0.8rem; color: var(--muted2); }
.lang-select {
  padding: 8px 12px; border-radius: 8px;
  background: var(--surface2); border: 1px solid var(--border2);
  color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 0.8rem;
  outline: none; cursor: pointer;
}

/* Translation panel */
.translation-panel { display: none; }
.translation-panel.active { display: block; }
.trans-row { display: flex; gap: 10px; align-items: flex-end; margin-bottom: 10px; flex-wrap: wrap; }
.trans-textarea {
  flex: 1; min-width: 200px; background: var(--surface); border: 1px solid var(--border);
  border-radius: 10px; padding: 10px; color: var(--text);
  font-family: 'DM Sans', sans-serif; font-size: 0.875rem; resize: vertical;
  min-height: 80px; outline: none; transition: border-color 0.2s;
}
.trans-textarea:focus { border-color: rgba(183,148,246,0.4); }
.trans-lang-select {
  padding: 10px 14px; border-radius: 10px;
  background: var(--surface); border: 1px solid var(--border);
  color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 0.875rem; outline: none;
}
.btn-translate {
  padding: 10px 20px; border-radius: 10px;
  background: rgba(183,148,246,0.15); border: 1px solid rgba(183,148,246,0.3);
  color: #b794f4; font-family: 'DM Sans', sans-serif; font-size: 0.875rem;
  cursor: pointer; transition: all 0.2s; white-space: nowrap;
}
.btn-translate:hover { background: rgba(183,148,246,0.25); }

.input-footer { display: flex; align-items: center; gap: 6px; margin-top: 8px; }
.input-footer-note { font-size: 0.72rem; color: var(--muted); flex: 1; }
.model-badge {
  font-size: 0.7rem; padding: 2px 8px; border-radius: 100px;
  background: rgba(99,179,237,0.08); border: 1px solid var(--border); color: var(--muted2);
}

/* Toast */
.toast {
  position: fixed; bottom: 24px; right: 24px; z-index: 9999;
  padding: 12px 20px; border-radius: 10px; font-size: 0.875rem;
  background: var(--surface2); border: 1px solid var(--border);
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
  animation: toastIn 0.3s ease; display: flex; align-items: center; gap: 8px;
}
.toast.error { border-color: rgba(252,129,129,0.3); color: var(--danger); }
.toast.success { border-color: rgba(104,211,145,0.3); color: var(--accent3); }
@keyframes toastIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

/* Mobile sidebar toggle */
.sidebar-toggle { display: none; }

@media (max-width: 768px) {
  :root { --sidebar-w: 80vw; }
  .sidebar { position: fixed; left: 0; top: var(--header-h); bottom: 0; z-index: 200; transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 199; }
  .sidebar-overlay.active { display: block; }
  .sidebar-toggle { display: flex; }
  .msg-content { max-width: 85%; }
  .mode-tabs { overflow-x: auto; }
  .mode-tabs::-webkit-scrollbar { display: none; }
}
</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <button class="btn-icon sidebar-toggle" id="sidebarToggle" title="Menu">
    <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
  <div class="header-logo">
    <div class="header-logo-icon">
      <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
    </div>
    GroqAI
  </div>
  <div class="header-spacer"></div>
  <div class="header-user">
    <div class="avatar">{{ request.user.username|first|upper }}</div>
    <span style="display:none;" class="d-sm-inline">{{ request.user.username }}</span>
    <a href="{% url 'logout' %}" class="btn-icon" title="Sair">
      <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    </a>
  </div>
</header>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="app-body">
  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-section">
      <div class="sidebar-label">Novo</div>
      <div class="mode-grid">
        <button class="mode-btn active" data-mode="chat" onclick="newConversation('chat')">
          <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Chat
        </button>
        <button class="mode-btn" data-mode="vision" onclick="newConversation('vision')">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/></svg>
          Visão
        </button>
        <button class="mode-btn" data-mode="transcription" onclick="newConversation('transcription')">
          <svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          Áudio
        </button>
        <button class="mode-btn" data-mode="translation" onclick="newConversation('translation')">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Tradução
        </button>
      </div>
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section" style="padding-bottom:4px;">
      <div class="sidebar-label">Conversas</div>
    </div>

    <div class="conversations-list" id="convList">
      {% for conv in conversations %}
      <div class="conv-item {% if active_conversation and active_conversation.id == conv.id %}active{% endif %}"
           data-id="{{ conv.id }}" data-mode="{{ conv.mode }}" onclick="loadConversation({{ conv.id }})">
        <div class="conv-dot"></div>
        <div class="conv-title">{{ conv.title }}</div>
        <button class="conv-del" onclick="deleteConversation(event, {{ conv.id }})">
          <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      {% empty %}
      <div style="padding:12px 6px; font-size:0.78rem; color:var(--muted); text-align:center; line-height:1.5;">
        Nenhuma conversa ainda.<br>Clique em um modo acima para começar.
      </div>
      {% endfor %}
    </div>
  </aside>

  <!-- CHAT MAIN -->
  <main class="chat-area">
    <!-- No conversation selected -->
    <div id="emptyState" class="empty-state" {% if active_conversation %}style="display:none"{% endif %}>
      <div class="empty-icon">
        <svg viewBox="0 0 24 24"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      </div>
      <h3>Bem-vindo ao GroqAI</h3>
      <p>Selecione um modo e inicie uma conversa. Explore chat inteligente, análise de imagens, transcrição de áudio e tradução.</p>
      <div class="suggestions">
        <div class="suggestion-chip" onclick="quickStart('chat','Explique o que é inteligência artificial')">💡 O que é IA?</div>
        <div class="suggestion-chip" onclick="quickStart('chat','Escreva um poema sobre o Brasil')">✍️ Escreva um poema</div>
        <div class="suggestion-chip" onclick="quickStart('chat','Quais são as últimas tendências em tecnologia?')">🚀 Tendências tech</div>
        <div class="suggestion-chip" onclick="quickStart('vision',null)">🖼️ Analisar imagem</div>
      </div>
    </div>

    <!-- Active conversation -->
    <div id="chatInterface" {% if not active_conversation %}style="display:none"{% endif %} style="display:flex;flex-direction:column;flex:1;overflow:hidden;">
      <div class="chat-header">
        <div class="chat-header-title" id="chatTitle">{% if active_conversation %}{{ active_conversation.title }}{% endif %}</div>
        <span class="mode-badge" id="modeBadge">{% if active_conversation %}{{ active_conversation.get_mode_display }}{% endif %}</span>
      </div>

      <div class="messages-container" id="messagesContainer">
        {% for msg in messages %}
        <div class="message {{ msg.role }}">
          <div class="msg-avatar">{% if msg.role == 'user' %}{{ request.user.username|first|upper }}{% else %}AI{% endif %}</div>
          <div class="msg-content">
            {% if msg.image %}<img src="{{ msg.image.url }}" class="msg-image" alt="Imagem">{% endif %}
            <div class="msg-bubble" data-raw="{{ msg.content }}"></div>
            <div class="msg-time">{{ msg.created_at|date:"H:i" }}</div>
          </div>
        </div>
        {% endfor %}
      </div>

      <!-- INPUT AREA -->
      <div class="input-area">
        <!-- Mode tabs -->
        <div class="mode-tabs" id="inputModeTabs">
          <button class="mode-tab active" id="tabChat" onclick="switchInputMode('chat')">
            <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Chat
          </button>
          <button class="mode-tab" id="tabVision" onclick="switchInputMode('vision')">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/></svg>
            Imagem
          </button>
          <button class="mode-tab" id="tabAudio" onclick="switchInputMode('transcription')">
            <svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg>
            Áudio
          </button>
          <button class="mode-tab" id="tabTrans" onclick="switchInputMode('translation')">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            Tradução
          </button>
        </div>

        <!-- Chat input -->
        <div class="input-panel" id="panelChat">
          <div class="chat-input-wrap">
            <textarea class="chat-textarea" id="chatInput" placeholder="Digite sua mensagem..." rows="1"></textarea>
            <button class="btn-send" id="btnSend" onclick="sendMessage()">
              <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </div>
        </div>

        <!-- Vision input -->
        <div class="input-panel vision-panel" id="panelVision">
          <div id="dropZone" class="drop-zone" onclick="document.getElementById('imageInput').click()">
            <input type="file" id="imageInput" accept="image/*" onchange="handleImageSelect(this)">
            <div class="drop-zone-icon">🖼️</div>
            <p><strong>Clique para selecionar</strong> ou arraste uma imagem aqui</p>
            <p style="margin-top:4px;font-size:0.75rem;">JPG, PNG, GIF, WebP — máx. 20MB</p>
          </div>
          <div id="imagePreviewWrap" style="display:none;" class="image-preview">
            <img id="imagePreviewImg" src="" alt="Preview">
            <div class="image-preview-del" onclick="clearImage()">✕</div>
          </div>
          <div class="chat-input-wrap" style="margin-top:8px;">
            <textarea class="chat-textarea" id="visionPrompt" placeholder="O que deseja saber sobre esta imagem? (opcional)" rows="1"></textarea>
            <button class="btn-send" id="btnVision" onclick="sendVision()" style="background:linear-gradient(135deg,var(--accent2),#ed8936);">
              <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </div>
        </div>

        <!-- Audio input -->
        <div class="input-panel audio-panel" id="panelAudio">
          <div class="audio-controls">
            <button class="btn-record" id="btnRecord" onclick="toggleRecording()">
              <div class="record-dot"></div>
              <span id="recordLabel">Gravar Áudio</span>
            </button>
            <label class="audio-file-label">
              <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Enviar arquivo
              <input type="file" class="audio-file-input" id="audioFileInput" accept="audio/*,.mp3,.wav,.ogg,.m4a,.flac,.webm" onchange="handleAudioFile(this)">
            </label>
            <select class="lang-select" id="audioLang">
              <option value="pt">Português</option>
              <option value="en">English</option>
              <option value="es">Español</option>
              <option value="fr">Français</option>
              <option value="de">Deutsch</option>
              <option value="it">Italiano</option>
              <option value="ja">日本語</option>
              <option value="zh">中文</option>
            </select>
            <button class="btn-send" id="btnTranscribe" onclick="sendAudio()" style="width:auto;padding:0 16px;background:linear-gradient(135deg,var(--accent3),#38a169);">
              <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </div>
          <div id="audioStatus" style="margin-top:8px;font-size:0.8rem;color:var(--muted2);"></div>
        </div>

        <!-- Translation input -->
        <div class="input-panel translation-panel" id="panelTrans">
          <div class="trans-row">
            <textarea class="trans-textarea" id="transInput" placeholder="Digite o texto para traduzir..."></textarea>
            <select class="trans-lang-select" id="transLang">
              <option value="inglês">🇺🇸 Inglês</option>
              <option value="espanhol">🇪🇸 Espanhol</option>
              <option value="português">🇧🇷 Português</option>
              <option value="francês">🇫🇷 Francês</option>
              <option value="alemão">🇩🇪 Alemão</option>
              <option value="italiano">🇮🇹 Italiano</option>
              <option value="japonês">🇯🇵 Japonês</option>
              <option value="chinês">🇨🇳 Chinês</option>
              <option value="russo">🇷🇺 Russo</option>
            </select>
            <button class="btn-translate" onclick="sendTranslation()">Traduzir</button>
          </div>
        </div>

        <div class="input-footer">
          <span class="input-footer-note">Pressione Enter para enviar, Shift+Enter para nova linha</span>
          <span class="model-badge" id="modelBadge">llama-3.3-70b</span>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
const CSRF = '{{ csrf_token }}';
let currentConvId = {% if active_conversation %}{{ active_conversation.id }}{% else %}null{% endif %};
let currentMode = '{% if active_conversation %}{{ active_conversation.mode }}{% else %}chat{% endif %}';
let isLoading = false;
let mediaRecorder = null;
let audioChunks = [];
let audioBlob = null;
let selectedImage = null;
let selectedAudioFile = null;

// ── Render markdown-ish content ──
function renderContent(text) {
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/```[\w]*\n([\s\S]*?)```/g, '<pre>$1</pre>')
    .replace(/\n/g, '<br>');
}

// ── Render all existing messages ──
document.querySelectorAll('.msg-bubble[data-raw]').forEach(el => {
  el.innerHTML = renderContent(el.dataset.raw);
});

// ── Sidebar mobile ──
document.getElementById('sidebarToggle').onclick = () => {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('active');
};
document.getElementById('sidebarOverlay').onclick = () => {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('active');
};

// ── New conversation ──
async function newConversation(mode) {
  const res = await fetch('/api/conversation/new/', {
    method: 'POST',
    headers: {'Content-Type':'application/json','X-CSRFToken':CSRF},
    body: JSON.stringify({mode})
  });
  const data = await res.json();
  currentConvId = data.id;
  currentMode = mode;

  // Add to sidebar
  const list = document.getElementById('convList');
  document.querySelectorAll('.conv-item').forEach(i => i.classList.remove('active'));
  const item = document.createElement('div');
  item.className = 'conv-item active';
  item.dataset.id = data.id;
  item.dataset.mode = mode;
  item.innerHTML = `<div class="conv-dot"></div><div class="conv-title">${data.title}</div><button class="conv-del" onclick="deleteConversation(event,${data.id})"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>`;
  item.onclick = () => loadConversation(data.id);
  list.prepend(item);

  // Show chat interface
  document.getElementById('emptyState').style.display = 'none';
  const ci = document.getElementById('chatInterface');
  ci.style.display = 'flex';
  ci.style.flexDirection = 'column';
  ci.style.flex = '1';
  ci.style.overflow = 'hidden';
  document.getElementById('chatTitle').textContent = data.title;
  document.getElementById('messagesContainer').innerHTML = '';

  updateModeUI(mode);
  switchInputMode(mode);

  // Mode buttons in sidebar
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  document.querySelector(`.mode-btn[data-mode="${mode}"]`)?.classList.add('active');

  // Mobile: close sidebar
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('active');
}

// ── Load conversation ──
async function loadConversation(id) {
  const res = await fetch(`/api/conversation/${id}/messages/`);
  const data = await res.json();
  currentConvId = id;
  currentMode = data.mode;

  document.querySelectorAll('.conv-item').forEach(i => i.classList.remove('active'));
  document.querySelector(`.conv-item[data-id="${id}"]`)?.classList.add('active');

  document.getElementById('emptyState').style.display = 'none';
  const ci = document.getElementById('chatInterface');
  ci.style.display = 'flex';
  ci.style.flexDirection = 'column';
  ci.style.flex = '1';
  ci.style.overflow = 'hidden';
  document.getElementById('chatTitle').textContent = data.title;

  const container = document.getElementById('messagesContainer');
  container.innerHTML = '';
  data.messages.forEach(m => appendMessage(m.role, m.content, m.image_url, m.created_at));

  updateModeUI(data.mode);
  switchInputMode(data.mode);

  // Mobile
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('active');
}

function updateModeUI(mode) {
  const badge = document.getElementById('modeBadge');
  const labels = {chat:'Chat',vision:'Visão',transcription:'Transcrição',translation:'Tradução'};
  badge.textContent = labels[mode] || mode;
  badge.className = 'mode-badge ' + mode;

  const models = {chat:'llama-3.3-70b',vision:'llama-4-scout',transcription:'whisper-large-v3',translation:'llama-3.3-70b'};
  document.getElementById('modelBadge').textContent = models[mode] || 'llama-3.3-70b';
}

// ── Delete conversation ──
async function deleteConversation(e, id) {
  e.stopPropagation();
  if (!confirm('Excluir esta conversa?')) return;
  await fetch(`/api/conversation/${id}/delete/`, {method:'DELETE',headers:{'X-CSRFToken':CSRF}});
  document.querySelector(`.conv-item[data-id="${id}"]`)?.remove();
  if (currentConvId === id) {
    currentConvId = null;
    document.getElementById('chatInterface').style.display = 'none';
    document.getElementById('emptyState').style.display = '';
  }
}

// ── Append message ──
function appendMessage(role, content, imageUrl=null, time=null) {
  const container = document.getElementById('messagesContainer');
  const initials = role === 'user' ? '{{ request.user.username|first|upper }}' : 'AI';
  const now = time || new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});

  const div = document.createElement('div');
  div.className = `message ${role}`;
  div.innerHTML = `
    <div class="msg-avatar">${initials}</div>
    <div class="msg-content">
      ${imageUrl ? `<img src="${imageUrl}" class="msg-image" alt="Imagem">` : ''}
      <div class="msg-bubble">${renderContent(content)}</div>
      <div class="msg-time">${now}</div>
    </div>`;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
  return div;
}

// ── Typing indicator ──
function showTyping() {
  const container = document.getElementById('messagesContainer');
  const div = document.createElement('div');
  div.className = 'message assistant';
  div.id = 'typingIndicator';
  div.innerHTML = `<div class="msg-avatar">AI</div><div class="msg-content"><div class="msg-bubble"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div></div>`;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}
function hideTyping() { document.getElementById('typingIndicator')?.remove(); }

// ── Send chat message ──
async function sendMessage() {
  if (isLoading || !currentConvId) return;
  const input = document.getElementById('chatInput');
  const content = input.value.trim();
  if (!content) return;

  isLoading = true;
  document.getElementById('btnSend').disabled = true;
  appendMessage('user', content);
  input.value = '';
  input.style.height = 'auto';
  showTyping();

  try {
    const res = await fetch('/api/message/send/', {
      method:'POST',
      headers:{'Content-Type':'application/json','X-CSRFToken':CSRF},
      body: JSON.stringify({conversation_id: currentConvId, content})
    });
    const data = await res.json();
    hideTyping();
    appendMessage('assistant', data.reply);
    updateConvTitle(currentConvId, data.title);
  } catch(e) {
    hideTyping();
    appendMessage('assistant', 'Erro de conexão. Tente novamente.');
  }

  isLoading = false;
  document.getElementById('btnSend').disabled = false;
  input.focus();
}

// ── Send vision ──
async function sendVision() {
  if (isLoading || !currentConvId || !selectedImage) { showToast('Selecione uma imagem primeiro.', 'error'); return; }

  isLoading = true;
  document.getElementById('btnVision').disabled = true;
  const prompt = document.getElementById('visionPrompt').value.trim() || 'Descreva esta imagem detalhadamente.';

  appendMessage('user', prompt, URL.createObjectURL(selectedImage));
  showTyping();

  const formData = new FormData();
  formData.append('conversation_id', currentConvId);
  formData.append('prompt', prompt);
  formData.append('image', selectedImage);

  try {
    const res = await fetch('/api/image/analyze/', {method:'POST',headers:{'X-CSRFToken':CSRF},body:formData});
    const data = await res.json();
    hideTyping();
    appendMessage('assistant', data.reply);
    updateConvTitle(currentConvId, data.title);
  } catch(e) {
    hideTyping();
    appendMessage('assistant', 'Erro ao analisar a imagem.');
  }

  clearImage();
  document.getElementById('visionPrompt').value = '';
  isLoading = false;
  document.getElementById('btnVision').disabled = false;
}

// ── Send audio ──
async function sendAudio() {
  if (isLoading || !currentConvId) return;
  let file;
  if (audioBlob) {
    const mime = audioBlob.type || 'audio/webm';
    const extMap = { 'audio/webm': 'webm', 'audio/ogg': 'ogg', 'audio/mp4': 'mp4', 'audio/mpeg': 'mp3' };
    const ext = extMap[mime.split(';')[0]] || 'webm';
    file = new File([audioBlob], 'recording.' + ext, { type: mime });
  } else {
    file = selectedAudioFile;
  }
  if (!file) { showToast('Grave ou selecione um arquivo de áudio.', 'error'); return; }

  isLoading = true;
  document.getElementById('btnTranscribe').disabled = true;
  appendMessage('user', '🎙️ Áudio enviado para transcrição...');
  showTyping();

  const lang = document.getElementById('audioLang').value;
  const formData = new FormData();
  formData.append('conversation_id', currentConvId);
  formData.append('audio', file);
  formData.append('language', lang);

  try {
    const res = await fetch('/api/audio/transcribe/', {method:'POST',headers:{'X-CSRFToken':CSRF},body:formData});
    const data = await res.json();
    hideTyping();
    if (data.error) appendMessage('assistant', `❌ ${data.error}`);
    else appendMessage('assistant', data.reply);
    updateConvTitle(currentConvId, data.title);
  } catch(e) {
    hideTyping();
    appendMessage('assistant', 'Erro ao processar o áudio.');
  }

  audioBlob = null;
  selectedAudioFile = null;
  document.getElementById('audioStatus').textContent = '';
  isLoading = false;
  document.getElementById('btnTranscribe').disabled = false;
}

// ── Translation ──
async function sendTranslation() {
  if (isLoading || !currentConvId) return;
  const text = document.getElementById('transInput').value.trim();
  if (!text) { showToast('Digite o texto para traduzir.', 'error'); return; }

  isLoading = true;
  const targetLang = document.getElementById('transLang').value;
  appendMessage('user', `Traduzir para ${targetLang}:\n\n${text}`);
  showTyping();

  try {
    const res = await fetch('/api/text/translate/', {
      method:'POST',
      headers:{'Content-Type':'application/json','X-CSRFToken':CSRF},
      body: JSON.stringify({conversation_id:currentConvId,text,target_lang:targetLang})
    });
    const data = await res.json();
    hideTyping();
    appendMessage('assistant', data.reply);
    updateConvTitle(currentConvId, data.title);
  } catch(e) {
    hideTyping();
    appendMessage('assistant', 'Erro na tradução.');
  }

  document.getElementById('transInput').value = '';
  isLoading = false;
}

// ── Switch input mode ──
function switchInputMode(mode) {
  ['chat','vision','transcription','translation'].forEach(m => {
    const panelMap = {chat:'panelChat',vision:'panelVision',transcription:'panelAudio',translation:'panelTrans'};
    document.getElementById(panelMap[m])?.classList.remove('active');
  });
  const panelMap = {chat:'panelChat',vision:'panelVision',transcription:'panelAudio',translation:'panelTrans'};
  document.getElementById(panelMap[mode])?.classList.add('active');

  ['tabChat','tabVision','tabAudio','tabTrans'].forEach(t => document.getElementById(t)?.classList.remove('active'));
  const tabMap = {chat:'tabChat',vision:'tabVision',transcription:'tabAudio',translation:'tabTrans'};
  document.getElementById(tabMap[mode])?.classList.add('active');
}

// ── Image handling ──
function handleImageSelect(input) {
  const file = input.files[0];
  if (!file) return;
  selectedImage = file;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('imagePreviewImg').src = e.target.result;
    document.getElementById('imagePreviewWrap').style.display = 'inline-block';
    document.getElementById('dropZone').style.display = 'none';
  };
  reader.readAsDataURL(file);
}

function clearImage() {
  selectedImage = null;
  document.getElementById('imageInput').value = '';
  document.getElementById('imagePreviewWrap').style.display = 'none';
  document.getElementById('dropZone').style.display = '';
}

// Drop zone drag
const dz = document.getElementById('dropZone');
dz?.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('dragover'); });
dz?.addEventListener('dragleave', () => dz.classList.remove('dragover'));
dz?.addEventListener('drop', e => {
  e.preventDefault(); dz.classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (file?.type.startsWith('image/')) {
    selectedImage = file;
    const reader = new FileReader();
    reader.onload = ev => {
      document.getElementById('imagePreviewImg').src = ev.target.result;
      document.getElementById('imagePreviewWrap').style.display = 'inline-block';
      dz.style.display = 'none';
    };
    reader.readAsDataURL(file);
  }
});

// ── Audio recording ──
async function toggleRecording() {
  if (mediaRecorder && mediaRecorder.state === 'recording') {
    mediaRecorder.stop();
    document.getElementById('btnRecord').classList.remove('recording');
    document.getElementById('recordLabel').textContent = 'Gravar Áudio';
    return;
  }

  // Verificar se a API está disponível
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    const isHttp = location.protocol === 'http:' && location.hostname !== 'localhost' && location.hostname !== '127.0.0.1';
    if (isHttp) {
      showToast('⚠️ Gravação exige HTTPS. Use o upload de arquivo no celular.', 'error');
      document.getElementById('audioStatus').innerHTML =
        '⚠️ <strong>Celular via rede local:</strong> a gravação pelo microfone requer HTTPS. ' +
        'Use o botão <em>"Enviar arquivo"</em> para carregar um áudio gravado.';
    } else {
      showToast('Seu navegador não suporta gravação de áudio.', 'error');
    }
    return;
  }

  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    audioChunks = [];

    // Detectar melhor formato suportado (compatibilidade mobile/desktop)
    const mimeTypes = [
      'audio/webm;codecs=opus',
      'audio/webm',
      'audio/ogg;codecs=opus',
      'audio/ogg',
      'audio/mp4',
      '',
    ];
    const supportedMime = mimeTypes.find(m => !m || MediaRecorder.isTypeSupported(m));
    const options = supportedMime ? { mimeType: supportedMime } : {};

    mediaRecorder = new MediaRecorder(stream, options);
    mediaRecorder.ondataavailable = e => { if (e.data && e.data.size > 0) audioChunks.push(e.data); };
    mediaRecorder.onstop = () => {
      const mimeUsed = mediaRecorder.mimeType || 'audio/webm';
      audioBlob = new Blob(audioChunks, { type: mimeUsed });
      stream.getTracks().forEach(t => t.stop());
      const kb = (audioBlob.size / 1024).toFixed(1);
      document.getElementById('audioStatus').textContent = `✅ Gravação pronta — ${kb}KB (${mimeUsed.split(';')[0]})`;
    };
    mediaRecorder.onerror = err => {
      showToast('Erro durante a gravação: ' + err.error?.message, 'error');
      stream.getTracks().forEach(t => t.stop());
      document.getElementById('btnRecord').classList.remove('recording');
      document.getElementById('recordLabel').textContent = 'Gravar Áudio';
    };

    mediaRecorder.start(250); // coleta dados a cada 250ms — mais robusto em mobile
    document.getElementById('btnRecord').classList.add('recording');
    document.getElementById('recordLabel').textContent = 'Parar Gravação';
    document.getElementById('audioStatus').textContent = '🔴 Gravando...';

  } catch (e) {
    let msg = 'Erro ao acessar o microfone.';
    if (e.name === 'NotAllowedError') msg = 'Permissão negada. Autorize o microfone nas configurações do navegador.';
    else if (e.name === 'NotFoundError') msg = 'Nenhum microfone encontrado no dispositivo.';
    else if (e.name === 'NotReadableError') msg = 'Microfone em uso por outro app.';
    else if (e.name === 'SecurityError') msg = 'Bloqueado por segurança. Acesse via HTTPS ou localhost.';
    showToast(msg, 'error');
    document.getElementById('audioStatus').textContent = '❌ ' + msg;
  }
}

function handleAudioFile(input) {
  selectedAudioFile = input.files[0];
  if (selectedAudioFile) {
    document.getElementById('audioStatus').textContent = `📁 ${selectedAudioFile.name} (${(selectedAudioFile.size/1024).toFixed(1)}KB)`;
  }
}

// ── Quick start from empty state ──
async function quickStart(mode, message) {
  await newConversation(mode);
  if (message && mode === 'chat') {
    document.getElementById('chatInput').value = message;
    sendMessage();
  }
}

// ── Update conversation title in sidebar ──
function updateConvTitle(id, title) {
  const el = document.querySelector(`.conv-item[data-id="${id}"] .conv-title`);
  if (el) el.textContent = title;
  if (currentConvId === id) document.getElementById('chatTitle').textContent = title;
}

// ── Toast notification ──
function showToast(msg, type='info') {
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = msg;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}

// ── Auto-resize textarea ──
document.getElementById('chatInput')?.addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 150) + 'px';
});

document.getElementById('chatInput')?.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});

// ── Auto-scroll on load ──
const mc = document.getElementById('messagesContainer');
if (mc) mc.scrollTop = mc.scrollHeight;

// ── Set initial input mode based on conversation mode ──
if (currentMode) switchInputMode(currentMode);
</script>
